{
  "info": {
    "name": "Event System Integration Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "item": [

    {
      "name": "1 Health check",
      "request": {
        "method": "GET",
        "url": "http://backend:8080/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Body contains OK', function () {",
              "    pm.expect(pm.response.text()).to.include('OK');",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "2 Add venue",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "text/plain" }
        ],
        "body": {
          "mode": "raw",
          "raw": "Concert Hall"
        },
        "url": "http://backend:8080/api/venues"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Venue added', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "3 Get venues",
      "request": {
        "method": "GET",
        "url": "http://backend:8080/api/venues"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "4 Count venues",
      "request": {
        "method": "GET",
        "url": "http://backend:8080/api/venues/count"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Count endpoint works', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "5 Clear venues",
      "request": {
        "method": "DELETE",
        "url": "http://backend:8080/api/venues"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete works', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }

  ]
}
